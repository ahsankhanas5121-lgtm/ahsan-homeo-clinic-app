# Database Configuration
DATABASE_URL=postgresql://ahsan_clinic:secure_password@localhost:5432/ahsan_homeo_clinic
DATABASE_ECHO=False

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=True

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Clinic Information
CLINIC_NAME=Ahsan Homeo Clinic & Store
CLINIC_LOCATION=Karachi, Pakistan
ONLINE_CONSULTATION_FEE=500
CLINIC_PHONE=03001234567
CLINIC_EMAIL=clinic@ahsanhomeo.com

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@ahsanhomeo.com

# WhatsApp Configuration (Optional)
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_ID=your-phone-id

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_EXTENSIONS=["pdf","jpg","jpeg","png","xlsx","xls"]

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
